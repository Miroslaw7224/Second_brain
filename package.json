{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build",
    "preview": "next start",
    "clean": "rm -rf dist .next",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prune": "ts-prune",
    "start": "next start",
    "migrate:sqlite-to-firestore": "tsx scripts/migrate-sqlite-to-firestore.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:local": "cross-env RUN_INTEGRATION_TESTS=1 vitest run --config vitest.integration.config.ts",
    "emulator:docker": "docker compose -f docker-compose-test.yml up -d",
    "test:integration:docker": "docker compose -f docker-compose-test.yml up -d && wait-on tcp:localhost:8080 && cross-env FIRESTORE_EMULATOR_HOST=localhost:8080 RUN_INTEGRATION_TESTS=1 vitest run --config vitest.integration.config.ts && docker compose -f docker-compose-test.yml down",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "playwright:cli": "playwright-cli",
    "playwright:cli:help": "playwright-cli --help",
    "playwright:cli:skills": "playwright-cli install --skills",
    "vercel": "vercel",
    "vercel:prod": "vercel --prod",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@tiptap/extension-color": "^3.20.0",
    "@tiptap/extension-font-family": "^3.20.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-text-style": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^14.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.6",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.4.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.14",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vercel": "^50.25.4",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  }
}
